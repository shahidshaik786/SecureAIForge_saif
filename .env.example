# SAIF - Secure AI Forge
# AI-assisted authorized Web/API security testing, evidence, and reporting forge.
# Independent project; not affiliated with Google SAIF / Secure AI Framework.

DATABASE_URL=postgresql+psycopg2://saif:saifpass@127.0.0.1:5433/saif_db
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_READ_TIMEOUT_SECONDS=240
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SECONDS=5
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=768
OLLAMA_TEMPERATURE=0.1
OLLAMA_KEEP_ALIVE=10m
OLLAMA_FALLBACK_MODEL=qwen2.5-coder:7b
OLLAMA_FAST_MODEL=qwen2.5-coder:7b
OLLAMA_DEEP_MODEL=
AI_MAX_EVIDENCE_CHARS=12000
AI_MAX_ENDPOINTS_IN_PROMPT=30
AI_MAX_FINDINGS_IN_PROMPT=20
AI_MAX_TOKEN_SAMPLES=0
SAIF_MAX_PARALLEL_AI_CALLS=1
SAIF_MAX_PARALLEL_AGENTS=3
SAIF_MAX_PARALLEL_TOOLS=2
SAIF_MAX_HTTP_REQUESTS_PER_SECOND=5
SAIF_TOOL_TIMEOUT_SECONDS=300
SAIF_CRAWLER_MAX_DEPTH=2
SAIF_CRAWLER_MAX_URLS=200
SAIF_DIR_DISCOVERY_MAX_WORDS=5000
SAIF_APT_UPGRADE=false
WORDLIST_WEB_COMMON=
SAIF_MAX_AI_PAYLOAD_ITERATIONS=5
SAIF_MAX_PAYLOADS_PER_PARAMETER=20
SAIF_MAX_TEST_TIME_PER_ENDPOINT_SECONDS=120
SAIF_SSRF_CALLBACK_URL=
SAIF_LOG_DIR=.saif/logs
SAIF_SCAN_HEARTBEAT_SECONDS=10
SAIF_SCAN_STALE_AFTER_SECONDS=120
SAIF_DASHBOARD_HOST=127.0.0.1
SAIF_DASHBOARD_PORT=8787
SAIF_DASHBOARD_USERNAME=
SAIF_DASHBOARD_PASSWORD=
SAIF_ALLOW_SECRET_VIEW=false
SHODAN_API_KEY=
